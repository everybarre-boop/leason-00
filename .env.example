# Supabase (클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Drizzle / Postgres 연결 문자열 (Supabase > Project Settings > Database > Connection string)
# Connection pooler(포트 6543)의 transaction 모드 사용을 권장한다.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# Resend (리드 접수 시 운영자에게 알림 메일 발송)
# API 키: https://resend.com/api-keys 에서 발급
RESEND_API_KEY=re_your-api-key
# 알림을 받을 운영자 이메일 (내 메일 주소)
LEAD_NOTIFICATION_TO=you@example.com
# 발신 주소. Resend에서 인증한 도메인이어야 한다. 미설정 시 테스트용 onboarding@resend.dev 사용
# 예) noreply@yourdomain.com
LEAD_NOTIFICATION_FROM=

# PostHog (클라이언트 방문/전환 분석)
# 프로젝트 API 키: PostHog > Settings > Project > Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
# 리전에 맞는 호스트. 미국: https://us.i.posthog.com, EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
