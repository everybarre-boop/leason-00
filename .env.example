# Supabase (클라이언트에서 사용)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Drizzle / Postgres 연결 문자열 (Supabase > Project Settings > Database > Connection string)
# Connection pooler(포트 6543)의 transaction 모드 사용을 권장한다.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
